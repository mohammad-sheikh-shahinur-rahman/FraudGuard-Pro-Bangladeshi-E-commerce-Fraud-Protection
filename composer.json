{
    "name": "mohammad-sheikh-shahinur-rahman/bkash-tokenized-checkout-devhub",
    "description": "Professional-grade bKash Tokenized Checkout (v1.2.0-beta) integration playground and developer guide for Laravel and Raw PHP.",
    "keywords": ["bkash", "payment-gateway", "laravel", "php", "tokenized-checkout", "fintech", "bangladesh"],
    "homepage": "https://github.com/mohammad-sheikh-shahinur-rahman/bKash-Tokenized-Checkout-DevHub",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Mohammad Sheikh Shahinur RAHMAN",
            "email": "shahinur.rahman@example.com",
            "homepage": "https://www.linkedin.com/in/mohammad-sheikh-shahinur-rahman/",
            "role": "CTO & Software Engineer"
        }
    ],
    "support": {
        "issues": "https://github.com/mohammad-sheikh-shahinur-rahman/bKash-Tokenized-Checkout-DevHub/issues",
        "source": "https://github.com/mohammad-sheikh-shahinur-rahman/bKash-Tokenized-Checkout-DevHub"
    },
    "require": {
        "php": ">=7.4",
        "guzzlehttp/guzzle": "^7.0",
        "illuminate/support": "^8.0|^9.0|^10.0"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://composer.pkg.github.com/mohammad-sheikh-shahinur-rahman"
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "App\\": "packages/laravel/app/",
            "Shahinur\\Bkash\\": "packages/php-sdk/"
        }
    },
    "minimum-stability": "beta",
    "prefer-stable": true,
    "extra": {
        "laravel": {
            "providers": [
                "App\\Providers\\BkashServiceProvider"
            ],
            "aliases": {
                "Bkash": "App\\Facades\\Bkash"
            }
        }
    }
}
